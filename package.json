        "category": "%command.category%",
        "icon": "$(add)"
      },
      {
        "command": "svn-tree.ignore-resource",
        "title": "%command.ignoreResource.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.add-group",
        "title": "%command.addGroup.title%",
        "category": "%command.category%",
        "icon": "$(add)"
      },
      {
        "command": "svn-tree.delete-resource",
        "title": "%command.deleteResource.title%",
        "category": "%command.category%",
        "icon": "$(trash)"
      },
      {
        "command": "svn-tree.rename-path",
        "title": "%command.renamePath.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.lock-path",
        "title": "%command.lockPath.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.unlock-path",
        "title": "%command.unlockPath.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.ignore-path",
        "title": "%command.ignorePath.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.unignore-path",
        "title": "%command.unignorePath.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.edit-ignore",
        "title": "%command.editIgnore.title%",
        "category": "%command.category%",
        "icon": "$(edit)"
      },
      {
        "command": "svn-tree.show-path-info",
        "title": "%command.showPathInfo.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.copy-repository-url",
        "title": "%command.copyRepositoryUrl.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.copy-repository-path",
