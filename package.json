{
  "name": "svn-graph",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.4.0",
  "publisher": "codetypess",
  "license": "MIT",
  "icon": "media/icon.png",
  "homepage": "https://github.com/codetypess/vscode-svn-graph#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/codetypess/vscode-svn-graph.git"
  },
  "bugs": {
    "url": "https://github.com/codetypess/vscode-svn-graph/issues"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "svn",
    "scm",
    "source control",
    "history",
    "diff"
  ],
  "galleryBanner": {
    "color": "#08111d",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "svn-graph.refresh",
        "title": "%command.refresh.title%",
        "category": "%command.category%",
        "icon": "$(refresh)"
      },
      {
        "command": "svn-graph.commit",
        "title": "%command.commit.title%",
        "category": "%command.category%",
        "icon": "$(check)"
      },
      {
        "command": "svn-graph.update",
        "title": "%command.update.title%",
        "category": "%command.category%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "svn-graph.cleanup",
        "title": "%command.cleanup.title%",
        "category": "%command.category%",
        "icon": "$(tools)"
      },
      {
        "command": "svn-graph.open-history",
        "title": "%command.openHistory.title%",
        "category": "%command.category%",
        "icon": "$(git-branch)"
      },
      {
        "command": "svn-graph.open-repository-actions",
        "title": "%command.openRepositoryActions.title%",
        "category": "%command.category%",
        "icon": "$(ellipsis)"
      },
      {
        "command": "svn-graph.show-output",
        "title": "%command.showOutput.title%",
        "category": "%command.category%",
        "icon": "$(output)"
      },
      {
        "command": "svn-graph.open-diff",
        "title": "%command.openDiff.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-graph.open-file",
        "title": "%command.openFile.title%",
        "category": "%command.category%",
        "icon": "$(go-to-file)"
      },
      {
        "command": "svn-graph.revert-resource",
        "title": "%command.revertResource.title%",
        "category": "%command.category%",
        "icon": "$(discard)"
      },
      {
        "command": "svn-graph.revert-group",
        "title": "%command.revertGroup.title%",
        "category": "%command.category%",
        "icon": "$(discard)"
      },
      {
        "command": "svn-graph.add-resource",
        "title": "%command.addResource.title%",
        "category": "%command.category%",
        "icon": "$(add)"
      },
      {
        "command": "svn-graph.add-group",
        "title": "%command.addGroup.title%",
        "category": "%command.category%",
        "icon": "$(add)"
      },
      {
        "command": "svn-graph.delete-resource",
        "title": "%command.deleteResource.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-graph.open-history-diff",
        "title": "%command.openHistoryDiff.title%",
        "category": "%command.category%"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "svn-graph.commit",
          "when": "scmProvider == svn-graph",
          "group": "navigation@1"
        },
        {
          "command": "svn-graph.refresh",
          "when": "scmProvider == svn-graph",
          "group": "navigation@2"
        }
      ],
      "scm/repository": [
        {
          "command": "svn-graph.open-repository-actions",
          "when": "scmProvider == svn-graph",
          "group": "inline@1"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "svn-graph.open-diff",
          "when": "scmProvider == svn-graph",
          "group": "navigation@1"
        },
        {
          "command": "svn-graph.open-file",
          "when": "scmProvider == svn-graph && scmResourceState != svn-remote-change",
          "group": "inline@1"
        },
        {
          "command": "svn-graph.add-resource",
          "when": "scmProvider == svn-graph && scmResourceState == svn-unversioned",
          "group": "inline@2"
        },
        {
          "command": "svn-graph.revert-resource",
          "when": "scmProvider == svn-graph && scmResourceState == svn-change",
          "group": "inline@2"
        },
        {
          "command": "svn-graph.delete-resource",
          "when": "scmProvider == svn-graph && scmResourceState == svn-unversioned",
          "group": "navigation@4"
        }
      ],
      "scm/resourceGroup/context": [
        {
          "command": "svn-graph.revert-group",
          "when": "scmProvider == svn-graph && scmResourceGroupState == svn-changes-group",
          "group": "inline@1"
        },
        {
          "command": "svn-graph.add-group",
          "when": "scmProvider == svn-graph && scmResourceGroupState == svn-unversioned-group",
          "group": "inline@1"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "svn-graph.display-language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "en",
            "zh-CN"
          ],
          "enumDescriptions": [
            "%config.displayLanguage.auto%",
            "%config.displayLanguage.en%",
            "%config.displayLanguage.zhCN%"
          ],
          "description": "%config.displayLanguage.description%",
          "scope": "window"
        },
        "svn-graph.enable-remote-status": {
          "type": "boolean",
          "default": true,
          "description": "%config.enableRemoteStatus.description%"
        },
        "svn-graph.remote-status-interval-seconds": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "description": "%config.remoteStatusIntervalSeconds.description%"
        },
        "svn-graph.max-log-entries": {
          "type": "number",
          "default": 200,
          "minimum": 20,
          "description": "%config.maxLogEntries.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "format": "prettier --write src",
    "compile": "tsc -p ./ && npm run compile:webview",
    "typecheck:webview": "tsc -p ./tsconfig.webview.json --noEmit",
    "compile:webview": "npm run typecheck:webview && esbuild src/history/history-panel-webview.tsx --bundle --format=iife --platform=browser --target=es2022 --minify --outfile=media/history-panel-webview.js",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node --test ./out/test/**/*.test.js"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "fast-xml-parser": "^4.5.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.95.0",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.3",
    "typescript": "^5.7.2"
  }
}
