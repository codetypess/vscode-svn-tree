  "version": "1.2.1",
  "publisher": "codetypess",
  "license": "MIT",
  "icon": "media/icon.png",
  "homepage": "https://github.com/codetypess/vscode-svn-tree#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/codetypess/vscode-svn-tree.git"
  },
  "bugs": {
    "url": "https://github.com/codetypess/vscode-svn-tree/issues"
  },
  "engines": {
