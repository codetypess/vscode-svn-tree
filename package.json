        "category": "%command.category%",
        "icon": "$(trash)"
      },
      {
        "command": "svn-tree.open-history-diff",
        "title": "%command.openHistoryDiff.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.open-file-history",
        "title": "%command.openFileHistory.title%",
        "category": "%command.category%",
        "icon": "$(history)"
      },
      {
        "command": "svn-tree.resolve-conflict",
        "title": "%command.resolveConflict.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.accept-mine",
        "title": "%command.acceptMine.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.accept-base",
        "title": "%command.acceptBase.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.accept-mine-conflict",
        "title": "%command.acceptMineConflict.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.accept-theirs-conflict",
