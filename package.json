        "category": "%command.category%"
      },
      {
        "command": "svn-tree.accept-base-all",
        "title": "%command.acceptBaseAll.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.accept-mine-conflict-all",
        "title": "%command.acceptMineConflictAll.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.accept-theirs-conflict-all",
        "title": "%command.acceptTheirsConflictAll.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.accept-theirs-all",
        "title": "%command.acceptTheirsAll.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.postpone-conflict",
        "title": "%command.postponeConflict.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.postpone-all-conflicts",
        "title": "%command.postponeAllConflicts.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.add-to-changelist",
        "title": "%command.addToChangelist.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.remove-from-changelist",
        "title": "%command.removeFromChangelist.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.reveal-in-file-manager",
        "title": "%command.revealInFileManager.title%",
        "category": "%command.category%"
      }
    ],
    "submenus": [
      {
        "id": "svn-tree.explorer",
        "label": "%command.category%"
      },
      {
        "id": "svn-tree.repository-actions",
        "label": "%command.openRepositoryActions.title%",
        "icon": "$(ellipsis)"
      },
      {
        "id": "svn-tree.repository-actions.browse",
        "label": "%submenu.repositoryBrowse.label%"
      },
      {
        "id": "svn-tree.repository-actions.working-copy",
        "label": "%submenu.repositoryWorkingCopy.label%"
      },
      {
        "id": "svn-tree.repository-actions.changes",
        "label": "%submenu.repositoryChanges.label%"
      },
      {
        "id": "svn-tree.repository-actions.conflicts",
        "label": "%submenu.repositoryConflicts.label%"
      },
      {
        "id": "svn-tree.resource-actions.browse",
        "label": "%submenu.repositoryBrowse.label%"
      },
      {
        "id": "svn-tree.resource-actions.changes",
        "label": "%submenu.repositoryChanges.label%"
      },
      {
        "id": "svn-tree.resource-actions.path",
        "label": "%submenu.resourcePath.label%"
      },
      {
        "id": "svn-tree.resource-actions.conflicts",
        "label": "%submenu.repositoryConflicts.label%"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "svn-tree.explorer",
          "when": "resourceScheme == file",
          "group": "4_svn@1"
        }
      ],
      "svn-tree.explorer": [
        {
          "command": "svn-tree.rename-path",
          "when": "resourceScheme == file",
          "group": "1_edit@1"
        },
        {
          "command": "svn-tree.show-properties",
          "when": "resourceScheme == file",
          "group": "1_edit@2"
        },
        {
          "command": "svn-tree.edit-property",
          "when": "resourceScheme == file",
          "group": "1_edit@3"
        },
        {
          "command": "svn-tree.open-repository-browser",
          "when": "resourceScheme == file",
          "group": "2_history@1"
        },
        {
          "command": "svn-tree.open-file-history",
          "when": "explorerResourceIsFolder == false && resourceScheme == file",
          "group": "2_history@2"
        },
        {
          "command": "svn-tree.open-revision-graph",
          "when": "resourceScheme == file",
          "group": "2_history@3"
        },
        {
          "command": "svn-tree.show-blame",
          "when": "explorerResourceIsFolder == false && resourceScheme == file",
          "group": "2_history@4"
        },
        {
          "command": "svn-tree.copy-repository-url",
          "when": "resourceScheme == file",
          "group": "3_copy@1"
        },
        {
          "command": "svn-tree.copy-repository-path",
          "when": "resourceScheme == file",
          "group": "3_copy@2"
        },
        {
          "command": "svn-tree.lock-path",
          "when": "explorerResourceIsFolder == false && resourceScheme == file",
          "group": "4_lock@1"
        },
        {
          "command": "svn-tree.unlock-path",
          "when": "explorerResourceIsFolder == false && resourceScheme == file",
          "group": "4_lock@2"
        },
        {
          "command": "svn-tree.ignore-path",
          "when": "resourceScheme == file",
          "group": "5_ignore@1"
        },
        {
          "command": "svn-tree.unignore-path",
          "when": "resourceScheme == file",
          "group": "5_ignore@2"
        },
        {
          "command": "svn-tree.edit-ignore",
          "when": "resourceScheme == file",
          "group": "5_ignore@3"
        },
        {
          "command": "svn-tree.show-path-info",
          "when": "resourceScheme == file",
          "group": "6_info@1"
        }
      ],
      "scm/title": [
        {
          "command": "svn-tree.commit",
          "when": "scmProvider == svn-tree",
          "group": "navigation@1"
        },
        {
          "command": "svn-tree.refresh",
          "when": "scmProvider == svn-tree",
          "group": "navigation@2"
        }
      ],
      "scm/repository": [
        {
          "submenu": "svn-tree.repository-actions",
          "when": "scmProvider == svn-tree",
          "group": "inline@1"
        }
      ],
      "svn-tree.repository-actions": [
        {
          "command": "svn-tree.refresh",
          "group": "1_common@1"
        },
        {
          "command": "svn-tree.update",
          "group": "1_common@2"
        },
        {
          "command": "svn-tree.commit",
          "group": "1_common@3"
        },
        {
          "command": "svn-tree.cleanup",
          "group": "1_common@4"
        },
        {
          "command": "svn-tree.show-output",
          "group": "1_common@5"
        },
        {
          "submenu": "svn-tree.repository-actions.browse",
          "group": "2_browse@1"
        },
        {
          "submenu": "svn-tree.repository-actions.working-copy",
          "group": "3_working_copy@1"
        },
        {
          "submenu": "svn-tree.repository-actions.changes",
          "group": "4_changes@1"
        },
        {
          "submenu": "svn-tree.repository-actions.conflicts",
          "group": "5_conflicts@1"
        }
      ],
      "svn-tree.repository-actions.browse": [
        {
          "command": "svn-tree.open-history",
          "group": "1_browse@1"
        },
        {
          "command": "svn-tree.open-revision-graph",
          "group": "1_browse@2"
        },
        {
          "command": "svn-tree.open-repository-browser",
          "group": "1_browse@3"
        }
      ],
      "svn-tree.repository-actions.working-copy": [
        {
          "command": "svn-tree.update-to-revision",
          "group": "1_working_copy@1"
        },
        {
          "command": "svn-tree.switch-reference",
          "group": "1_working_copy@2"
        },
        {
          "command": "svn-tree.merge-into-working-copy",
          "group": "1_working_copy@3"
        },
        {
          "command": "svn-tree.create-branch-from-working-copy",
          "group": "1_working_copy@4"
        },
        {
          "command": "svn-tree.create-tag-from-working-copy",
          "group": "1_working_copy@5"
        },
        {
          "command": "svn-tree.delete-reference",
          "group": "1_working_copy@6"
        },
        {
          "command": "svn-tree.relocate-working-copy",
          "group": "1_working_copy@7"
        },
        {
          "command": "svn-tree.edit-ignore",
          "group": "1_working_copy@8"
        }
      ],
      "svn-tree.repository-actions.changes": [
        {
          "command": "svn-tree.commit-changelist",
          "group": "1_changes@1"
        },
        {
          "command": "svn-tree.add-group",
          "group": "1_changes@2"
        },
        {
          "command": "svn-tree.delete-group",
          "group": "1_changes@3"
        },
        {
          "command": "svn-tree.revert-group",
          "group": "1_changes@4"
        }
      ],
      "svn-tree.repository-actions.conflicts": [
        {
          "command": "svn-tree.resolve-all-conflicts",
          "group": "1_conflicts@1"
        },
        {
          "command": "svn-tree.accept-mine-all",
          "group": "1_conflicts@2"
        },
        {
          "command": "svn-tree.accept-base-all",
          "group": "1_conflicts@3"
        },
        {
          "command": "svn-tree.accept-mine-conflict-all",
          "group": "1_conflicts@4"
        },
        {
          "command": "svn-tree.accept-theirs-conflict-all",
          "group": "1_conflicts@5"
        },
        {
          "command": "svn-tree.accept-theirs-all",
          "group": "1_conflicts@6"
        },
        {
          "command": "svn-tree.postpone-all-conflicts",
          "group": "1_conflicts@7"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "svn-tree.open-diff",
          "when": "scmProvider == svn-tree",
          "group": "navigation@1"
        },
        {
          "command": "svn-tree.open-file",
          "when": "scmProvider == svn-tree && scmResourceState != svn-remote-change",
          "group": "inline@1"
        },
        {
          "command": "svn-tree.open-file-history",
          "when": "scmProvider == svn-tree && (scmResourceState == svn-change || scmResourceState == svn-conflict || scmResourceState == svn-remote-change)",
          "group": "navigation@2"
        },
        {
          "command": "svn-tree.add-resource",
          "when": "scmProvider == svn-tree && scmResourceState == svn-unversioned",
          "group": "inline@2"
        },
        {
          "command": "svn-tree.delete-resource",
          "when": "scmProvider == svn-tree && scmResourceState == svn-unversioned",
          "group": "inline@3"
        },
        {
          "command": "svn-tree.revert-resource",
          "when": "scmProvider == svn-tree && (scmResourceState == svn-change || scmResourceState == svn-conflict)",
          "group": "inline@2"
        },
        {
          "command": "svn-tree.resolve-conflict",
          "when": "scmProvider == svn-tree && scmResourceState == svn-conflict",
          "group": "navigation@3"
        },
        {
          "command": "svn-tree.commit-selected",
          "when": "scmProvider == svn-tree && scmResourceState == svn-change",
          "group": "1_primary@1"
        },
        {
          "command": "svn-tree.delete-resource",
          "when": "scmProvider == svn-tree && (scmResourceState == svn-change || scmResourceState == svn-unversioned)",
          "group": "1_primary@5"
        },
        {
          "command": "svn-tree.rename-path",
          "when": "scmProvider == svn-tree && (scmResourceState == svn-change || scmResourceState == svn-conflict || scmResourceState == svn-unversioned)",
          "group": "1_primary@2"
        },
        {
          "command": "svn-tree.reveal-in-file-manager",
          "when": "scmProvider == svn-tree",
          "group": "1_primary@3"
        },
        {
          "command": "svn-tree.ignore-resource",
          "when": "scmProvider == svn-tree && scmResourceState == svn-unversioned",
          "group": "1_primary@4"
        },
        {
          "command": "svn-tree.edit-ignore",
          "when": "scmProvider == svn-tree && scmResourceState == svn-unversioned",
          "group": "1_primary@6"
        },
        {
          "submenu": "svn-tree.resource-actions.browse",
          "when": "scmProvider == svn-tree && (scmResourceState == svn-change || scmResourceState == svn-conflict || scmResourceState == svn-remote-change)",
          "group": "2_browse@1"
        },
        {
          "submenu": "svn-tree.resource-actions.changes",
          "when": "scmProvider == svn-tree && (scmResourceState == svn-change || scmResourceState == svn-conflict)",
          "group": "3_changes@1"
        },
        {
          "submenu": "svn-tree.resource-actions.path",
          "when": "scmProvider == svn-tree && (scmResourceState == svn-change || scmResourceState == svn-conflict || scmResourceState == svn-remote-change)",
          "group": "4_path@1"
        },
        {
          "submenu": "svn-tree.resource-actions.conflicts",
          "when": "scmProvider == svn-tree && scmResourceState == svn-conflict",
          "group": "5_conflict@1"
        }
      ],
      "svn-tree.resource-actions.browse": [
        {
          "command": "svn-tree.open-repository-browser",
          "group": "1_browse@1"
        },
        {
          "command": "svn-tree.open-revision-graph",
          "group": "1_browse@2"
        },
        {
          "command": "svn-tree.show-blame",
          "group": "1_browse@3"
        }
      ],
      "svn-tree.resource-actions.changes": [
        {
          "command": "svn-tree.update-selected",
          "when": "scmProvider == svn-tree && scmResourceState == svn-change",
          "group": "1_changes@1"
        },
        {
          "command": "svn-tree.update-selected-to-revision",
          "when": "scmProvider == svn-tree && scmResourceState == svn-change",
          "group": "1_changes@2"
        },
        {
          "command": "svn-tree.add-to-changelist",
          "when": "scmProvider == svn-tree && (scmResourceState == svn-change || scmResourceState == svn-conflict)",
          "group": "1_changes@3"
        },
        {
          "command": "svn-tree.remove-from-changelist",
          "when": "scmProvider == svn-tree && (scmResourceState == svn-change || scmResourceState == svn-conflict)",
          "group": "1_changes@4"
        },
        {
          "command": "svn-tree.lock-path",
          "when": "scmProvider == svn-tree && (scmResourceState == svn-change || scmResourceState == svn-conflict)",
          "group": "1_changes@5"
        },
        {
          "command": "svn-tree.unlock-path",
          "when": "scmProvider == svn-tree && (scmResourceState == svn-change || scmResourceState == svn-conflict)",
          "group": "1_changes@6"
        }
      ],
      "svn-tree.resource-actions.path": [
        {
          "command": "svn-tree.show-properties",
          "group": "1_path@1"
        },
        {
          "command": "svn-tree.edit-property",
          "group": "1_path@2"
        },
        {
          "command": "svn-tree.edit-ignore",
          "group": "1_path@3"
        },
        {
          "command": "svn-tree.copy-repository-url",
          "group": "1_path@4"
        },
        {
          "command": "svn-tree.copy-repository-path",
          "group": "1_path@5"
        },
        {
          "command": "svn-tree.show-path-info",
          "group": "1_path@6"
        }
      ],
      "svn-tree.resource-actions.conflicts": [
        {
          "command": "svn-tree.accept-mine",
          "group": "1_conflict@1"
        },
        {
          "command": "svn-tree.accept-base",
          "group": "1_conflict@2"
        },
        {
          "command": "svn-tree.accept-mine-conflict",
          "group": "1_conflict@3"
        },
        {
          "command": "svn-tree.accept-theirs-conflict",
          "group": "1_conflict@4"
        },
        {
          "command": "svn-tree.accept-theirs",
          "group": "1_conflict@5"
        },
        {
          "command": "svn-tree.postpone-conflict",
          "group": "1_conflict@6"
        }
      ],
      "scm/resourceGroup/context": [
        {
          "command": "svn-tree.revert-group",
          "when": "scmProvider == svn-tree && scmResourceGroupState == svn-changes-group",
          "group": "inline@1"
        },
        {
          "command": "svn-tree.add-group",
          "when": "scmProvider == svn-tree && scmResourceGroupState == svn-unversioned-group",
          "group": "inline@1"
        },
        {
          "command": "svn-tree.delete-group",
          "when": "scmProvider == svn-tree && scmResourceGroupState == svn-unversioned-group",
          "group": "inline@2"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "svn-tree.displayLanguage": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "en",
            "zh-CN"
          ],
          "enumDescriptions": [
            "%config.displayLanguage.auto%",
            "%config.displayLanguage.en%",
            "%config.displayLanguage.zhCN%"
          ],
          "description": "%config.displayLanguage.description%",
          "scope": "window"
        },
        "svn-tree.enable-remote-status": {
          "type": "boolean",
          "default": true,
          "description": "%config.enableRemoteStatus.description%"
        },
        "svn-tree.remote-status-interval-seconds": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "description": "%config.remoteStatusIntervalSeconds.description%"
        },
        "svn-tree.max-log-entries": {
          "type": "number",
          "default": 200,
          "minimum": 20,
          "description": "%config.maxLogEntries.description%"
        },
        "svn-tree.revision-graph-trunk-names": {
          "type": "array",
          "default": [
            "trunk"
          ],
          "items": {
            "type": "string"
          },
          "description": "%config.revisionGraphTrunkNames.description%"
        },
        "svn-tree.revision-graph-branch-container-names": {
          "type": "array",
          "default": [
            "branches"
          ],
          "items": {
            "type": "string"
          },
          "description": "%config.revisionGraphBranchContainerNames.description%"
        },
        "svn-tree.revision-graph-tag-container-names": {
          "type": "array",
          "default": [
            "tags"
          ],
          "items": {
            "type": "string"
          },
          "description": "%config.revisionGraphTagContainerNames.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "format": "prettier --write src",
    "compile": "tsc -p ./ && npm run compile:webview",
    "typecheck:webview": "tsc -p ./tsconfig.webview.json --noEmit",
    "compile:webview": "npm run typecheck:webview && esbuild src/history/history-panel-webview.tsx src/revision-graph/revision-graph-webview.tsx --bundle --format=iife --platform=browser --target=es2022 --minify --outdir=media --entry-names=[name]",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node --test ./out/test/**/*.test.js"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "fast-xml-parser": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.95.0",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "typescript": "^5.7.2"
  }
}
