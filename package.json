        "category": "%command.category%"
      },
      {
        "command": "svn-tree.accept-theirs",
        "title": "%command.acceptTheirs.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.resolve-all-conflicts",
        "title": "%command.resolveAllConflicts.title%",
        "category": "%command.category%"
      },
      {
        "command": "svn-tree.accept-mine-all",
